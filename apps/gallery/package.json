{
	"name": "@yesid/gallery",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Living brand gallery — token sheets + motion demos rendered from @yesid/tokens and @yesid/motion. The dogfood consumer for @yesid/gates.",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest run"
	},
	"dependencies": {
		"@yesid/motion": "workspace:*",
		"@yesid/tokens": "workspace:*",
		"@yesid/ui": "workspace:*"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@tailwindcss/vite": "^4.1.18",
		"@yesid/gates": "workspace:*",
		"svelte": "^5.54.0",
		"svelte-check": "^4.1.0",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.5.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.0"
	}
}
