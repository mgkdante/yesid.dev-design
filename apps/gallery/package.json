{
	"name": "@yesid/gallery",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Living brand gallery — token sheets + motion demos rendered from @yesid/tokens and @yesid/motion. The dogfood consumer for @yesid/gates.",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest run",
		"browser:install": "playwright install chromium",
		"test:browser": "bun run build && playwright test --config playwright.config.ts"
	},
	"dependencies": {
		"@fontsource-variable/inter": "5.3.0",
		"@fontsource-variable/jetbrains-mono": "5.3.0",
		"@yesid/motion": "workspace:*",
		"@yesid/tokens": "workspace:*",
		"@yesid/ui": "workspace:*"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.12.1",
		"@playwright/test": "1.61.1",
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.1.18",
		"@yesid/gates": "workspace:*",
		"svelte": "^5.54.0",
		"svelte-check": "^4.1.0",
		"tailwindcss": "^4.1.18",
		"typescript": "^7.0.2",
		"vite": "^8.1.5",
		"vitest": "^4.1.0"
	}
}
