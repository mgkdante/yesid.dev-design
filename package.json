{
	"name": "yesid-dev-design",
	"version": "0.9.0",
	"private": true,
	"type": "module",
	"description": "yesid.dev brand foundation — tokens, motion, gates, UI, gallery. Parity anchor: yesid.dev @ 2bdb611d91749dc437c07586cb82129eabe9dfec.",
	"packageManager": "bun@1.3.11",
	"engines": {
		"bun": ">=1.3.0",
		"node": ">=22.0.0"
	},
	"workspaces": ["apps/*", "packages/*"],
	"scripts": {
		"api:approve": "bun tools/api-authority.ts approve",
		"api:check": "bun tools/api-authority.ts check",
		"api:report": "bun tools/api-authority.ts report",
		"config:release:build": "bun tools/config-release.ts build",
		"config:release:check": "bun tools/config-version.ts check",
		"config:release:prepare": "bun tools/config-version.ts prepare",
		"config:release:verify": "bun tools/config-release.ts verify",
		"release:check": "bun tools/release.ts check",
		"release:prepare": "bun tools/release.ts prepare",
		"scorecard:measure": "bun tools/phase2-scorecard.ts",
		"build": "bun run tokens:build && turbo run build",
		"test": "turbo run test",
		"test:browser": "bun run --cwd apps/gallery test:browser",
		"browser:install": "bun run --cwd apps/gallery browser:install",
		"check": "bun run api:check && tsc --project tsconfig.tools.json && turbo run check",
		"dev": "turbo run dev",
		"tokens:build": "bun tools/build-tokens.ts",
		"tokens:lint": "design.md lint DESIGN.md",
		"ci:tokens": "bun run tokens:build && git diff --exit-code packages/tokens/tokens.css apps/gallery/src/app.css packages/motion/src/tokens.ts DESIGN.md",
		"setup:hooks": "git config core.hooksPath .githooks"
	},
	"devDependencies": {
		"@google/design.md": "0.1.1",
		"@microsoft/api-extractor": "7.58.11",
		"@types/node": "^22.0.0",
		"@yesid/config": "workspace:0.2.0",
		"svelte2tsx": "0.7.58",
		"turbo": "^2.5.0",
		"typescript": "^5.9.3",
		"yaml": "2.9.0"
	},
	"patchedDependencies": {
		"bits-ui@2.18.1": "patches/bits-ui@2.18.1.patch"
	}
}
