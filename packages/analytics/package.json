{
	"name": "@yesid/analytics",
	"version": "0.11.0",
	"private": true,
	"type": "module",
	"description": "Consumer-neutral, consent-aware analytics policy, client, sanitization, and injected Plausible transport primitives.",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./client": {
			"types": "./src/client.ts",
			"default": "./src/client.ts"
		},
		"./config": {
			"types": "./src/config.ts",
			"default": "./src/config.ts"
		},
		"./consent": {
			"types": "./src/consent.svelte.ts",
			"default": "./src/consent.svelte.ts"
		},
		"./plausible": {
			"types": "./src/plausible.ts",
			"default": "./src/plausible.ts"
		},
		"./policy": {
			"types": "./src/policy.ts",
			"default": "./src/policy.ts"
		}
	},
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "tsc --noEmit"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"svelte": "^5.54.0",
		"typescript": "^5.5.0",
		"vitest": "^4.1.0"
	}
}
